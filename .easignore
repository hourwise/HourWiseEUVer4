gitignore
# Learn more: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
/node_modules

# Expo
/.expo
/dist
/web-build

# Local agent/worktree state
/.claude

# Native build artifacts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro bundler cache
.metro-health-check*
.metro-cache/

# General Caching
.cache/

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# -- CRITICAL: Local Environment Variables & Config --
# Ignore all .env files and sensitive config files.
.env
.env*.local
credentials.json

# TypeScript/test outputs
*.tsbuildinfo
/.test-dist
/coverage

# -- IDE and Editor Specific --
# VS Code
.vscode/
# Android Studio / IntelliJ
.idea/

# -- Generated Native Folders --
# These are generated by `npx expo prebuild` and should not be in git.
/ios
# /android <- Removed this line

# Android local/generated build state
/android/.gradle
/android/app/build
/android/build
/android/local.properties

/credentials/

# Local docs and Supabase assets are not needed for cloud mobile builds
/docs
/supabase
